{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "redirects": [
    { "source": "/password", "destination": "/password-generator", "permanent": true },
    { "source": "/passwords", "destination": "/password-generator", "permanent": true },
    { "source": "/encrypt", "destination": "/text-encrypt", "permanent": true },
    { "source": "/encryption", "destination": "/file-encrypt", "permanent": true },
    { "source": "/files", "destination": "/file-encrypt", "permanent": true },
    { "source": "/secret", "destination": "/one-time", "permanent": true },
    { "source": "/secrets", "destination": "/one-time", "permanent": true },
    { "source": "/otp", "destination": "/one-time", "permanent": true },
    { "source": "/2fa", "destination": "/ikrypt-guard", "permanent": true },
    { "source": "/authenticator", "destination": "/ikrypt-guard", "permanent": true },
    { "source": "/totp", "destination": "/ikrypt-guard", "permanent": true },
    { "source": "/notes", "destination": "/secure-notes", "permanent": true },
    { "source": "/signature", "destination": "/sign", "permanent": true },
    { "source": "/digital-signature", "destination": "/sign", "permanent": true },
    { "source": "/generate", "destination": "/password-generator", "permanent": true },
    { "source": "/key", "destination": "/keys", "permanent": true },
    { "source": "/keypair", "destination": "/keys", "permanent": true },
    { "source": "/hashing", "destination": "/hash", "permanent": true },
    { "source": "/shield", "destination": "/ikrypt-shield", "permanent": true },
    { "source": "/guard", "destination": "/ikrypt-guard", "permanent": true },
    { "source": "/code", "destination": "/ikrypt-code", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://www.clarity.ms; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://www.clarity.ms; connect-src 'self' https://*.firebaseio.com https://*.googleapis.com https://www.google-analytics.com https://analytics.google.com https://www.clarity.ms https://*.clarity.ms;"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
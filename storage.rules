rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /encrypted-files/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024 // 10MB limit
                  && request.resource.contentType.matches('application/.*');
      allow delete: if false;
    }
  }
}
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Encrypted pastes
    match /encrypted-pastes/{document=**} {
      allow read: if true;
      allow create: if request.resource.data.content is string
                   && request.resource.data.createdAt is string
                   && request.resource.data.expiresAt is string;
      allow delete: if false;
    }
    
    // One-time messages
    match /one-time-messages/{document=**} {
      allow read: if true;
      allow create: if request.resource.data.content is string
                   && request.resource.data.createdAt is string
                   && request.resource.data.expiresAt is string;
      allow delete: if true;
    }
    
    // Chat rooms
    match /chat-rooms/{roomId}/messages/{messageId} {
      allow read: if true;
      allow create: if request.resource.data.content is string
                   && request.resource.data.sender is string
                   && request.resource.data.timestamp is string;
      allow delete: if false;
    }
  }
}